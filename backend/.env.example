# ---- Kondani backend (.env) ----
# Copy to ".env" and fill in. NEVER commit the real .env.

# Server
PORT=3000
# Frontend origin(s) for CORS in production (comma-separated, no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# Database — MongoDB Atlas (free tier, never expires)
# Create a free cluster at https://www.mongodb.com/atlas, then paste the connection string:
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/kondani?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Telegram bot — ADMIN OTP RELAY (invisible to users)
# 1. Create a bot with @BotFather -> copy the token
# 2. Message your bot, then get your numeric chat id (e.g. via @userinfobot)
# When a user requests a code, the bot DMs it to you so you can SMS it manually.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudinary — photo hosting (free 25GB, persists on Render unlike local /uploads)
# Sign up at https://cloudinary.com -> Dashboard shows these three values:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
