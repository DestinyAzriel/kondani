# Environment Configuration Template
# Copy this to .env in the vue-project directory

# ============================================
# Backend API Configuration
# ============================================
# IMPORTANT: must include the /api suffix.
VITE_API_BASE_URL=http://localhost:3000/api

# Socket.io server URL (NO /api suffix). Used by socketService for realtime chat.
VITE_SOCKET_URL=http://localhost:3000

# In production, point both at your Render backend, e.g.
# VITE_API_BASE_URL=https://kondani-backend.onrender.com/api
# VITE_SOCKET_URL=https://kondani-backend.onrender.com

# ============================================
# WebRTC TURN/STUN Configuration
# ============================================

# Public STUN server (free, for development)
VITE_STUN_SERVER_URL=stun:stun.l.google.com:19302

# TURN server (required for production)
# Option 1: Managed service (Twilio, Xirsys, Metered.ca)
# VITE_TURN_SERVER_URL=turn:global.turn.twilio.com:3478?transport=udp
# VITE_TURN_USERNAME=your-twilio-username
# VITE_TURN_CREDENTIAL=your-twilio-credential

# Option 2: Self-hosted Coturn
# VITE_TURN_SERVER_URL=turn:your-server.com:3478
# VITE_TURN_USERNAME=kondani-user
# VITE_TURN_CREDENTIAL=your-secret-credential

# ============================================
# Optional: Feature Flags
# ============================================
# VITE_ENABLE_VIDEO_CALLS=true
# VITE_ENABLE_ANALYTICS=false
